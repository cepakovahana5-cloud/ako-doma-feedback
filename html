<!DOCTYPE html>
<html lang="sk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ako Doma Feedback</title>

<link rel="stylesheet" href="style.css">

</head>

<body>

<div class="card">

<img src="logo.png" class="logo">

<h1>Ďakujeme za návštevu ❤️</h1>

<p>Vaša spätná väzba nám pomáha zlepšovať naše služby.</p>

<form id="feedbackForm">

<label>Celkové hodnotenie</label>

<select id="rating">
<option>⭐⭐⭐⭐⭐</option>
<option>⭐⭐⭐⭐</option>
<option>⭐⭐⭐</option>
<option>⭐⭐</option>
<option>⭐</option>
</select>

<label>Komentár</label>

<textarea
id="comment"
placeholder="Napíšte nám váš názor..."></textarea>

<label>Email (voliteľné)</label>

<input
id="email"
type="email">

<button type="submit">
Odoslať
</button>

</form>

</div>

<script>

const SCRIPT_URL="https://script.google.com/macros/s/AKfycbySIyrCZqXIM4u2q3p05eZY4Cowtwmsf8a1bMUvck-okS-I2AsflBczMn3TORN2iiUd/exec";

document
.getElementById("feedbackForm")
.addEventListener("submit",async function(e){

e.preventDefault();

const data={
rating:document.getElementById("rating").value,
comment:document.getElementById("comment").value,
email:document.getElementById("email").value
};

try{

await fetch(SCRIPT_URL,{
method:"POST",
headers:{
"Content-Type":"application/json"
},
body:JSON.stringify(data)
});

alert("Ďakujeme za spätnú väzbu ❤️");

document.getElementById("feedbackForm").reset();

}catch(error){

alert("Nepodarilo sa odoslať formulár.");

}

});

</script>

</body>
</html>
